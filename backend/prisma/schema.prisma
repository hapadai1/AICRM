model RentalSku {
  id            String   @id @db.Uuid
  componentType String   @map("component_type") @db.VarChar(20)
  design        String   @map("design") @db.VarChar(100)
  color         String   @map("color") @db.VarChar(80)
  size          String   @map("size") @db.VarChar(40)
  description   String?  @map("description")
  active        Boolean  @default(true) @map("active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  inventoryItems RentalInventoryItem[]

  @@index([componentType, design, color, size])
  @@map("rental_skus")
}

model RentalInventoryItem {
  id             String    @id @db.Uuid
  managementCode String    @unique @map("management_code") @db.VarChar(60)
  rentalSkuId    String    @map("rental_sku_id") @db.Uuid
  status         String    @default("AVAILABLE") @map("status") @db.VarChar(25)
  availableFrom  DateTime? @map("available_from") @db.Date
  notes          String?   @map("notes")
  active         Boolean   @default(true) @map("active")
  acquiredAt     DateTime? @map("acquired_at") @db.Date
  retiredAt      DateTime? @map("retired_at") @db.Date
  rowVersion     Int       @default(0) @map("row_version")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  rentalSku           RentalSku                    @relation(fields: [rentalSkuId], references: [id])
  statusEvents        RentalInventoryStatusEvent[]
  allocations         RentalAllocation[]
  oldAllocationEvents RentalAllocationEvent[]      @relation("RentalAllocationEventOldItem")
  newAllocationEvents RentalAllocationEvent[]      @relation("RentalAllocationEventNewItem")
  repairRequests      RepairRequest[]

  @@index([status, availableFrom])
  @@map("rental_inventory_items")
}

model RentalAllocation {
  id                    String    @id @db.Uuid
  orderItemComponentId  String    @map("order_item_component_id") @db.Uuid
  rentalInventoryItemId String    @map("rental_inventory_item_id") @db.Uuid
  pickupDate            DateTime  @map("pickup_date") @db.Date
  returnDueDate         DateTime  @map("return_due_date") @db.Date
  availabilityEndDate   DateTime  @map("availability_end_date") @db.Date
  actualPickupAt        DateTime? @map("actual_pickup_at") @db.Timestamptz(6)
  actualReturnAt        DateTime? @map("actual_return_at") @db.Timestamptz(6)
  status                String    @default("RESERVED") @map("status") @db.VarChar(25)
  assignedBy            String    @map("assigned_by") @db.Uuid
  assignedAt            DateTime  @map("assigned_at") @db.Timestamptz(6)
  rowVersion            Int       @default(0) @map("row_version")
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  orderItemComponent  OrderItemComponent      @relation(fields: [orderItemComponentId], references: [id])
  rentalInventoryItem RentalInventoryItem     @relation(fields: [rentalInventoryItemId], references: [id])
  assignedByUser      User                    @relation("RentalAllocationAssignedBy", fields: [assignedBy], references: [id])
  events              RentalAllocationEvent[]

  @@index([rentalInventoryItemId, pickupDate, availabilityEndDate])
  @@index([returnDueDate, status])
  @@map("rental_allocations")
}

model RentalAllocationEvent {
  id                 String   @id @db.Uuid
  rentalAllocationId String   @map("rental_allocation_id") @db.Uuid
  eventType          String   @map("event_type") @db.VarChar(30)
  oldInventoryItemId String?  @map("old_inventory_item_id") @db.Uuid
  newInventoryItemId String?  @map("new_inventory_item_id") @db.Uuid
  reason             String?  @map("reason")
  actorId            String   @map("actor_id") @db.Uuid
  occurredAt         DateTime @default(now()) @map("occurred_at") @db.Timestamptz(6)

  rentalAllocation RentalAllocation     @relation(fields: [rentalAllocationId], references: [id])
  oldInventoryItem RentalInventoryItem? @relation("RentalAllocationEventOldItem", fields: [oldInventoryItemId], references: [id])
  newInventoryItem RentalInventoryItem? @relation("RentalAllocationEventNewItem", fields: [newInventoryItemId], references: [id])
  actor            User                 @relation("RentalAllocationEventActor", fields: [actorId], references: [id])

  @@index([rentalAllocationId, eventType])
  @@map("rental_allocation_events")
}

model RentalInventoryStatusEvent {
  id                    String    @id @db.Uuid
  rentalInventoryItemId String    @map("rental_inventory_item_id") @db.Uuid
  previousStatus        String?   @map("previous_status") @db.VarChar(25)
  newStatus             String    @map("new_status") @db.VarChar(25)
  availableFrom         DateTime? @map("available_from") @db.Date
  reason                String?   @map("reason")
  actorId               String    @map("actor_id") @db.Uuid
  occurredAt            DateTime  @default(now()) @map("occurred_at") @db.Timestamptz(6)

  rentalInventoryItem RentalInventoryItem @relation(fields: [rentalInventoryItemId], references: [id])
  actor               User                @relation("RentalInventoryStatusEventActor", fields: [actorId], references: [id])

  @@index([rentalInventoryItemId, occurredAt(sort: Desc)])
  @@map("rental_inventory_status_events")
}

