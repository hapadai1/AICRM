model MeasurementSession {
  id                String    @id @db.Uuid
  customerId        String    @map("customer_id") @db.Uuid
  relatedOrderId    String?   @map("related_order_id") @db.Uuid
  versionNo         Int       @map("version_no")
  measurementDate   DateTime  @map("measurement_date") @db.Date
  measurementType   String    @default("INITIAL") @map("measurement_type") @db.VarChar(20)
  previousSessionId String?   @map("previous_session_id") @db.Uuid
  fitPreference     String?   @map("fit_preference") @db.VarChar(100)
  bodyNotes         String?   @map("body_notes")
  notes             String?   @map("notes")
  completedAt       DateTime? @map("completed_at") @db.Timestamptz(6)
  createdBy         String    @map("created_by") @db.Uuid
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  customer          Customer               @relation(fields: [customerId], references: [id])
  relatedOrder      Order?                 @relation(fields: [relatedOrderId], references: [id])
  previousSession   MeasurementSession?    @relation("MeasurementSessionPrevious", fields: [previousSessionId], references: [id])
  nextSessions      MeasurementSession[]   @relation("MeasurementSessionPrevious")
  createdByUser     User                   @relation("MeasurementSessionCreatedBy", fields: [createdBy], references: [id])
  values            MeasurementValue[]
  orderItemLinks    OrderItemMeasurement[]
  workOrderVersions WorkOrderVersion[]

  @@unique([customerId, versionNo])
  @@index([customerId, measurementDate(sort: Desc)])
  @@map("measurement_sessions")
}

model MeasurementValue {
  id                   String   @id @db.Uuid
  measurementSessionId String   @map("measurement_session_id") @db.Uuid
  bodySection          String   @map("body_section") @db.VarChar(20)
  measurementCode      String   @map("measurement_code") @db.VarChar(40)
  numericValue         Decimal? @map("numeric_value") @db.Decimal(8, 2)
  textValue            String?  @map("text_value") @db.VarChar(40)
  unit                 String   @default("CM") @map("unit") @db.VarChar(10)
  sortOrder            Int      @default(0) @map("sort_order")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  measurementSession MeasurementSession @relation(fields: [measurementSessionId], references: [id])

  @@unique([measurementSessionId, measurementCode])
  @@index([bodySection])
  @@map("measurement_values")
}

model OrderItemMeasurement {
  id                   String   @id @db.Uuid
  orderItemId          String   @map("order_item_id") @db.Uuid
  measurementSessionId String   @map("measurement_session_id") @db.Uuid
  isCurrent            Boolean  @default(true) @map("is_current")
  linkedBy             String   @map("linked_by") @db.Uuid
  linkedAt             DateTime @default(now()) @map("linked_at") @db.Timestamptz(6)

  orderItem          OrderItem          @relation(fields: [orderItemId], references: [id])
  measurementSession MeasurementSession @relation(fields: [measurementSessionId], references: [id])
  linkedByUser       User               @relation("OrderItemMeasurementLinkedBy", fields: [linkedBy], references: [id])

  @@index([orderItemId, isCurrent])
  @@map("order_item_measurements")
}

