   */
  releaseMethod         String?   @map("release_method") @db.VarChar(20)
  pickupAddress         String?   @map("pickup_address") @db.VarChar(300)
  deliveryAddress       String?   @map("delivery_address") @db.VarChar(300)
  notes                 String?   @map("notes")
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  customer            Customer             @relation(fields: [customerId], references: [id])
  order               Order?               @relation(fields: [orderId], references: [id])
  orderItem           OrderItem?           @relation(fields: [orderItemId], references: [id])
  component           OrderItemComponent?  @relation(fields: [componentId], references: [id])
  rentalInventoryItem RentalInventoryItem? @relation(fields: [rentalInventoryItemId], references: [id])
  statusEvents        RepairStatusEvent[]

  @@index([requestDate])
  @@index([dueDate, status])
  @@map("repair_requests")
}

model RepairStatusEvent {
  id              String   @id @db.Uuid
  repairRequestId String   @map("repair_request_id") @db.Uuid
  previousStatus  String?  @map("previous_status") @db.VarChar(25)
  newStatus       String   @map("new_status") @db.VarChar(25)
  eventDate       DateTime @map("event_date") @db.Date
  notes           String?  @map("notes")
  actorId         String   @map("actor_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  repairRequest RepairRequest @relation(fields: [repairRequestId], references: [id])
  actor         User          @relation("RepairStatusEventActor", fields: [actorId], references: [id])

  @@index([repairRequestId, eventDate])
  @@map("repair_status_events")
}

model Payment {
  id            String   @id @db.Uuid
  contractId    String   @map("contract_id") @db.Uuid
  paymentType   String   @map("payment_type") @db.VarChar(20)
  amount        Decimal  @map("amount") @db.Decimal(14, 2)
  paymentDate   DateTime @map("payment_date") @db.Date
  paymentMethod String?  @map("payment_method") @db.VarChar(30)
  status        String   @default("COMPLETED") @map("status") @db.VarChar(20)
  memo          String?  @map("memo")
  cancelReason  String?  @map("cancel_reason")
  cancelledAt   DateTime? @map("cancelled_at") @db.Timestamptz(6)
  createdBy     String   @map("created_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  contract      Contract @relation(fields: [contractId], references: [id])
  createdByUser User     @relation("PaymentCreatedBy", fields: [createdBy], references: [id])

  @@index([contractId, paymentType])
  @@index([paymentDate, status])
  @@map("payments")
}

