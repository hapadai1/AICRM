model WorkOrder {
  id               String   @id @db.Uuid
  orderItemId      String   @unique @map("order_item_id") @db.Uuid
  currentVersionId String?  @map("current_version_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  orderItem      OrderItem          @relation(fields: [orderItemId], references: [id])
  currentVersion WorkOrderVersion?  @relation("WorkOrderCurrentVersion", fields: [currentVersionId], references: [id])
  versions       WorkOrderVersion[] @relation("WorkOrderVersions")

  @@map("work_orders")
}

model WorkOrderVersion {
  id                         String    @id @db.Uuid
  workOrderId                String    @map("work_order_id") @db.Uuid
  versionNo                  Int       @map("version_no")
  sourceOptionSessionId      String    @map("source_option_session_id") @db.Uuid
  sourceMeasurementSessionId String    @map("source_measurement_session_id") @db.Uuid
  optionSnapshot             Json      @map("option_snapshot")
  measurementSnapshot        Json      @map("measurement_snapshot")
  sourceHash                 String    @map("source_hash") @db.VarChar(64)
  changeReason               String?   @map("change_reason")
  outputFileId               String    @map("output_file_id") @db.Uuid
  status                     String    @default("ISSUED") @map("status") @db.VarChar(20)
  issuedBy                   String    @map("issued_by") @db.Uuid
  issuedAt                   DateTime  @map("issued_at") @db.Timestamptz(6)
  sentAt                     DateTime? @map("sent_at") @db.Timestamptz(6)
  updatedAt                  DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  workOrder                WorkOrder              @relation("WorkOrderVersions", fields: [workOrderId], references: [id])
  sourceOptionSession      OptionSelectionSession @relation(fields: [sourceOptionSessionId], references: [id])
  sourceMeasurementSession MeasurementSession     @relation(fields: [sourceMeasurementSessionId], references: [id])
  outputFile               File                   @relation(fields: [outputFileId], references: [id])
  issuedByUser             User                   @relation("WorkOrderVersionIssuedBy", fields: [issuedBy], references: [id])
  currentOfWorkOrders      WorkOrder[]            @relation("WorkOrderCurrentVersion")

  @@unique([workOrderId, versionNo])
  @@index([workOrderId, issuedAt(sort: Desc)])
  @@index([sourceHash])
  @@map("work_order_versions")
}

model ProductionEvent {
  id             String    @id @db.Uuid
  orderItemId    String    @map("order_item_id") @db.Uuid
  componentId    String?   @map("component_id") @db.Uuid
  eventType      String    @map("event_type") @db.VarChar(40)
