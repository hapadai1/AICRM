  customerId     String    @map("customer_id") @db.Uuid
  orderId        String?   @map("order_id") @db.Uuid
  recipientPhone String    @map("recipient_phone") @db.VarChar(30)
  /** 실제 발송 채널. 템플릿 채널과 다를 수 있다(알림톡 실패 → SMS 대체). */
  channel        String    @default("ALIMTALK") @map("channel") @db.VarChar(20)
  /** 변수 치환까지 끝난 실제 발송 본문. */
  body           String?   @map("body")
  status         String    @default("REQUESTED") @map("status") @db.VarChar(20)
  sentAt         DateTime? @map("sent_at") @db.Timestamptz(6)
  errorMessage   String?   @map("error_message")
  /** 재시도·대체 발송의 원본 이력. */
  retryOfId      String?   @map("retry_of_id") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  template      NotificationTemplate? @relation(fields: [templateId], references: [id])
  customer      Customer              @relation(fields: [customerId], references: [id])
  order         Order?                @relation(fields: [orderId], references: [id])
  retryOf       NotificationHistory?  @relation("NotificationRetry", fields: [retryOfId], references: [id])
  retries       NotificationHistory[] @relation("NotificationRetry")
  journeyEvents JourneyEvent[]

  @@index([customerId, createdAt(sort: Desc)])
  @@map("notification_history")
}

model SharedNote {
  id           String    @id @db.Uuid
  content      String    @map("content")
  targetUserId String?   @map("target_user_id") @db.Uuid
  authorId     String    @map("author_id") @db.Uuid
  status       String    @default("ACTIVE") @map("status") @db.VarChar(20)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)

  targetUser User? @relation("SharedNoteTarget", fields: [targetUserId], references: [id])
  author     User  @relation("SharedNoteAuthor", fields: [authorId], references: [id])

  @@map("shared_notes")
}

model DashboardTaskAction {
  id         String   @id @db.Uuid
  taskType   String   @map("task_type") @db.VarChar(30)
  entityType String   @map("entity_type") @db.VarChar(40)
  entityId   String   @map("entity_id") @db.Uuid
  status     String   @default("ACKNOWLEDGED") @map("status") @db.VarChar(20)
  memo       String?  @map("memo")
  actionBy   String   @map("action_by") @db.Uuid
  actionAt   DateTime @map("action_at") @db.Timestamptz(6)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  actionByUser User @relation("DashboardTaskActionActionBy", fields: [actionBy], references: [id])

  @@index([taskType, entityType, entityId])
  @@map("dashboard_task_actions")
}

// -----------------------------------------------------------------------------
// 인프라 (문서 외 추가 테이블)
// -----------------------------------------------------------------------------

model RefreshToken {
  id        String    @id @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("refresh_tokens")
}

model IdempotencyKey {
  id           String   @id @db.Uuid
  key          String   @unique @map("key") @db.VarChar(120)
  userId       String?  @map("user_id") @db.Uuid
  endpoint     String   @map("endpoint") @db.VarChar(150)
  responseJson Json?    @map("response_json")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User? @relation(fields: [userId], references: [id])

  @@map("idempotency_keys")
}

// -----------------------------------------------------------------------------
// 12. 고객 진행 단계 (설계 PDF 1페이지 업무흐름 — 개발설계서 05 G-11)
//
// 사람이 관리하는 표시 레이어다. order_items.status 등 시스템이 계산하는 상태를
// 대체하거나 자동 연동하지 않는다(이중 관리·롤백 충돌 방지). 단계 변경이 곧
// 고객 연락 트리거이며, 발송은 화면의 확인창을 거친다.
// -----------------------------------------------------------------------------

/**
 * 진행 단계 마스터. 시드 고정이되 이름·연락 템플릿 매핑은 관리자가 조정한다.
 */
model JourneyStage {
  id         String   @id @db.Uuid
  /**
   * CUSTOM(비즈니스 맞춤) | RENTAL(웨딩패키지 렌탈)
   */
  trackType  String   @map("track_type") @db.VarChar(20)
  code       String   @map("code") @db.VarChar(30)
  name       String   @map("name") @db.VarChar(60)
  sequenceNo Int      @map("sequence_no")
  /**
   * 이 단계 진입 시 제안할 알림 템플릿. 없으면 발송 제안 없음
   */
  templateId String?  @map("template_id") @db.Uuid
  active     Boolean  @default(true) @map("active")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  template NotificationTemplate? @relation(fields: [templateId], references: [id])
  events   JourneyEvent[]

  @@unique([trackType, code])
  @@unique([trackType, sequenceNo])
  @@map("journey_stages")
}

/**
 * 거래 1건의 진행. 계약 전에는 orderId가 비어 있다.
 */
model CustomerJourney {
  id               String    @id @db.Uuid
  customerId       String    @map("customer_id") @db.Uuid
  orderId          String?   @map("order_id") @db.Uuid
  trackType        String    @map("track_type") @db.VarChar(20)
  currentStageCode String    @map("current_stage_code") @db.VarChar(30)
  /**
   * ACTIVE | COMPLETED | CANCELLED
   */
  status           String    @default("ACTIVE") @map("status") @db.VarChar(20)
  startedAt        DateTime  @map("started_at") @db.Timestamptz(6)
  completedAt      DateTime? @map("completed_at") @db.Timestamptz(6)
  rowVersion       Int       @default(0) @map("row_version")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  customer Customer       @relation(fields: [customerId], references: [id])
  order    Order?         @relation(fields: [orderId], references: [id])
  events   JourneyEvent[]

  @@index([customerId, startedAt(sort: Desc)])
  @@index([status, currentStageCode])
  @@map("customer_journeys")
}

/**
 * 단계 변경 이력 + 그 시점의 고객 연락 처리 결과
 */
model JourneyEvent {
  id                    String   @id @db.Uuid
  journeyId             String   @map("journey_id") @db.Uuid
  stageId               String   @map("stage_id") @db.Uuid
  fromStageCode         String?  @map("from_stage_code") @db.VarChar(30)
  toStageCode           String   @map("to_stage_code") @db.VarChar(30)
  /**
   * 되돌리기(후진) 시 필수
   */
  reason                String?  @map("reason")
  notes                 String?  @map("notes")
  /**
   * NONE | SENT | DEFERRED | SKIPPED — 이 변경 시점의 고객 연락 처리 결과
   */
  notificationOutcome   String   @default("NONE") @map("notification_outcome") @db.VarChar(20)
  notificationHistoryId String?  @map("notification_history_id") @db.Uuid
  actorId               String   @map("actor_id") @db.Uuid
  changedAt             DateTime @map("changed_at") @db.Timestamptz(6)

  journey             CustomerJourney      @relation(fields: [journeyId], references: [id])
  stage               JourneyStage         @relation(fields: [stageId], references: [id])
  notificationHistory NotificationHistory? @relation(fields: [notificationHistoryId], references: [id])
  actor               User                 @relation("JourneyEventActor", fields: [actorId], references: [id])

  @@index([journeyId, changedAt(sort: Desc)])
  @@index([notificationOutcome])
  @@map("journey_events")
}
