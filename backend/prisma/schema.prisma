model RepairRequest {
  id                    String    @id @db.Uuid
  customerId            String    @map("customer_id") @db.Uuid
  orderId               String?   @map("order_id") @db.Uuid
  orderItemId           String?   @map("order_item_id") @db.Uuid
  componentId           String?   @map("component_id") @db.Uuid
  rentalInventoryItemId String?   @map("rental_inventory_item_id") @db.Uuid
  repairType            String    @map("repair_type") @db.VarChar(30)
  requestDate           DateTime  @map("request_date") @db.Date
  dueDate               DateTime? @map("due_date") @db.Date
  status                String    @default("RECEIVED") @map("status") @db.VarChar(25)
  description           String    @map("description")
  cost                  Decimal?  @map("cost") @db.Decimal(14, 2)
  /**
   * 접수 방식 (VISIT 고객 방문 | PICKUP 방문 수거)
   */
  receiptMethod         String?   @map("receipt_method") @db.VarChar(20)
  /**
