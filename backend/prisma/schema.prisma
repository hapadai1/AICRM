model FittingAdjustment {
  id               String   @id @db.Uuid
  fittingSessionId String   @map("fitting_session_id") @db.Uuid
  componentId      String?  @map("component_id") @db.Uuid
  /**
   * 표준 확인 항목 (SILHOUETTE | BALANCE | EASE | LENGTH | ETC) — 설계서 1페이지 가봉 단계
   */
  areaCode         String   @default("ETC") @map("area_code") @db.VarChar(20)
  /**
   * 세부 부위 자유입력 (예: 왼쪽 소매)
   */
  area             String   @map("area") @db.VarChar(80)
  instruction      String   @map("instruction")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  fittingSession FittingSession      @relation(fields: [fittingSessionId], references: [id])
  component      OrderItemComponent? @relation(fields: [componentId], references: [id])

  @@map("fitting_adjustments")
}

