// =============================================================================
// AICRM Prisma Schema
// 기준 문서: 02_AICRM_데이터모델설계서_v0.1 (16장 테이블 전체 목록)
//
// [주의] rental_allocations 기간 중복 방지 EXCLUDE 제약(문서 11.6)은 Prisma로
// 표현할 수 없으므로 마이그레이션 SQL에 아래 구문을 수기로 추가해야 한다:
//
//   CREATE EXTENSION IF NOT EXISTS btree_gist;
//   ALTER TABLE rental_allocations
//     ADD CONSTRAINT rental_allocation_no_overlap EXCLUDE USING gist (
//       rental_inventory_item_id WITH =,
//       daterange(pickup_date, availability_end_date, '[]') WITH &&
//     ) WHERE (status <> 'CANCELLED');
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// 1. 기반: 사용자·권한
// -----------------------------------------------------------------------------

model User {
  id           String    @id @db.Uuid
  loginId      String    @unique @map("login_id") @db.VarChar(80)
  displayName  String    @map("display_name") @db.VarChar(80)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  status       String    @default("ACTIVE") @map("status") @db.VarChar(20)
  lastLoginAt  DateTime? @map("last_login_at") @db.Timestamptz(6)
  rowVersion   Int       @default(0) @map("row_version")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  userRoles                   UserRole[]
  refreshTokens               RefreshToken[]
  idempotencyKeys             IdempotencyKey[]
  auditLogs                   AuditLog[]
  consultations               Consultation[]               @relation("ConsultationStaff")
  confirmedContractVersions   ContractVersion[]            @relation("ContractVersionConfirmedBy")
  createdContractVersions     ContractVersion[]            @relation("ContractVersionCreatedBy")
  createdOptionSetVersions    OptionSetVersion[]           @relation("OptionSetVersionCreatedBy")
  optionSelectionValues       OptionSelectionValue[]       @relation("OptionSelectionValueSelectedBy")
  createdMeasurementSessions  MeasurementSession[]         @relation("MeasurementSessionCreatedBy")
  linkedOrderItemMeasurements OrderItemMeasurement[]       @relation("OrderItemMeasurementLinkedBy")
  issuedWorkOrderVersions     WorkOrderVersion[]           @relation("WorkOrderVersionIssuedBy")
  productionEvents            ProductionEvent[]            @relation("ProductionEventActor")
  assignedRentalAllocations   RentalAllocation[]           @relation("RentalAllocationAssignedBy")
  rentalAllocationEvents      RentalAllocationEvent[]      @relation("RentalAllocationEventActor")
  rentalInventoryStatusEvents RentalInventoryStatusEvent[] @relation("RentalInventoryStatusEventActor")
  repairStatusEvents          RepairStatusEvent[]          @relation("RepairStatusEventActor")
  createdPayments             Payment[]                    @relation("PaymentCreatedBy")
  targetedSharedNotes         SharedNote[]                 @relation("SharedNoteTarget")
  authoredSharedNotes         SharedNote[]                 @relation("SharedNoteAuthor")
  dashboardTaskActions        DashboardTaskAction[]        @relation("DashboardTaskActionActionBy")
  journeyEvents               JourneyEvent[]               @relation("JourneyEventActor")

  @@map("users")
}

model Role {
  id          String   @id @db.Uuid
  code        String   @unique @map("code") @db.VarChar(50)
  name        String   @map("name") @db.VarChar(80)
  description String?  @map("description")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @db.Uuid
  code        String   @unique @map("code") @db.VarChar(80)
  name        String   @map("name") @db.VarChar(100)
  description String?  @map("description")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  rolePermissions RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// -----------------------------------------------------------------------------
// 1. 기반: 파일·감사로그
// -----------------------------------------------------------------------------

model File {
  id             String   @id @db.Uuid
  storageKey     String   @unique @map("storage_key") @db.VarChar(255)
  originalName   String   @map("original_name") @db.VarChar(255)
  mimeType       String   @map("mime_type") @db.VarChar(100)
  sizeBytes      BigInt   @map("size_bytes")
  checksumSha256 String?  @map("checksum_sha256") @db.VarChar(64)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  entityFiles             EntityFile[]
  optionChoices           OptionChoice[]
  workOrderVersionOutputs WorkOrderVersion[]

  @@map("files")
}

model EntityFile {
  id         String   @id @db.Uuid
  fileId     String   @map("file_id") @db.Uuid
  entityType String   @map("entity_type") @db.VarChar(50)
  entityId   String   @map("entity_id") @db.Uuid
  purpose    String   @map("purpose") @db.VarChar(30)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  file File @relation(fields: [fileId], references: [id])

  @@index([entityType, entityId])
  @@map("entity_files")
}

model AuditLog {
  id         String   @id @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String   @map("action") @db.VarChar(50)
  entityType String   @map("entity_type") @db.VarChar(60)
  entityId   String   @map("entity_id") @db.Uuid
  beforeJson Json?    @map("before_json")
  afterJson  Json?    @map("after_json")
  reason     String?  @map("reason")
  ipAddress  String?  @map("ip_address") @db.Inet
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User? @relation(fields: [userId], references: [id])

  @@index([entityType, entityId, createdAt(sort: Desc)])
  @@index([action])
  @@map("audit_logs")
}

// -----------------------------------------------------------------------------
// 2. 고객·예약·상담
// -----------------------------------------------------------------------------

model Customer {
  id              String    @id @db.Uuid
  name            String    @map("name") @db.VarChar(80)
  phone           String    @map("phone") @db.VarChar(30)
  phoneNormalized String    @unique @map("phone_normalized") @db.VarChar(20)
  email           String?   @map("email") @db.VarChar(255)
  customerStatus  String    @default("PROSPECT") @map("customer_status") @db.VarChar(20)
  firstReservedAt DateTime? @map("first_reserved_at") @db.Timestamptz(6)
  contractedAt    DateTime? @map("contracted_at") @db.Timestamptz(6)
  notes           String?   @map("notes")
  rowVersion      Int       @default(0) @map("row_version")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  appointments          Appointment[]
  consultations         Consultation[]
  contracts             Contract[]
  measurementSessions   MeasurementSession[]
  repairRequests        RepairRequest[]
  notificationHistories NotificationHistory[]
  journeys              CustomerJourney[]

  @@index([name])
  @@map("customers")
}

model AppointmentPurpose {
  id        String   @id @db.Uuid
  code      String   @unique @map("code") @db.VarChar(40)
  name      String   @map("name") @db.VarChar(80)
  sortOrder Int      @default(0) @map("sort_order")
  active    Boolean  @default(true) @map("active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  appointments Appointment[]

  @@map("appointment_purposes")
}

/** 결제수단 기준정보 (ADMIN-001, type=payment-method). 결제 등록 시 코드/표시명 소스. */
model PaymentMethod {
  id        String   @id @db.Uuid
  code      String   @unique @map("code") @db.VarChar(40)
  name      String   @map("name") @db.VarChar(80)
  sortOrder Int      @default(0) @map("sort_order")
  active    Boolean  @default(true) @map("active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("payment_methods")
}

/**
 * 코드 상수로 정의된 기준정보(품목·구성품·수선구분)의 표시명 오버라이드 (ADMIN-001).
 * 코드 집합·기본 표시명은 코드 상수(code-labels.constants)가 원본이며,
 * 이 테이블은 관리자가 바꾼 표시명만 저장한다(행 없으면 기본 표시명 사용).
 * 코드 추가·삭제는 불가하며 표시명만 편집 가능하다.
 */
model MasterCodeLabel {
  id        String   @id @db.Uuid
  domain    String   @map("domain") @db.VarChar(40)
  code      String   @map("code") @db.VarChar(40)
  label     String   @map("label") @db.VarChar(100)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([domain, code])
  @@map("master_code_labels")
}

model Appointment {
  id             String    @id @db.Uuid
  customerId     String    @map("customer_id") @db.Uuid
  source         String    @map("source") @db.VarChar(20)
  externalId     String?   @map("external_id") @db.VarChar(100)
  purposeId      String    @map("purpose_id") @db.Uuid
  scheduledStart DateTime  @map("scheduled_start") @db.Timestamptz(6)
  scheduledEnd   DateTime? @map("scheduled_end") @db.Timestamptz(6)
  status         String    @default("RESERVED") @map("status") @db.VarChar(20)
  notes          String?   @map("notes")
  naverUpdatedAt DateTime? @map("naver_updated_at") @db.Timestamptz(6)
  syncedAt       DateTime? @map("synced_at") @db.Timestamptz(6)
  localOverride  Boolean   @default(false) @map("local_override")
  rowVersion     Int       @default(0) @map("row_version")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  customer        Customer           @relation(fields: [customerId], references: [id])
  purpose         AppointmentPurpose @relation(fields: [purposeId], references: [id])
  consultations   Consultation[]
  fittingSessions FittingSession[]

  @@unique([source, externalId])
  @@index([scheduledStart, status])
  @@index([customerId])
  @@map("appointments")
}

model Consultation {
  id                   String    @id @db.Uuid
  customerId           String    @map("customer_id") @db.Uuid
  appointmentId        String?   @map("appointment_id") @db.Uuid
  consultedAt          DateTime  @map("consulted_at") @db.Timestamptz(6)
  consultationCategory String?   @map("consultation_category") @db.VarChar(30)
  content              String    @map("content")
  /**
   * 용도 (BUSINESS_CUSTOM | WEDDING_RENTAL) — 진행 단계 trackType과 1:1 대응
   */
  usageType            String?   @map("usage_type") @db.VarChar(30)
  /**
   * 예산 범위 (정수 원). 단일값이면 min=max
   */
  budgetMin            Int?      @map("budget_min")
  budgetMax            Int?      @map("budget_max")
  preferredStyle       String?   @map("preferred_style") @db.VarChar(200)
  /**
   * 고객이 희망한 납기 — 계약 시 orders.completion_due_date 기본값으로 제안
   */
  desiredDueDate       DateTime? @map("desired_due_date") @db.Date
  staffId              String    @map("staff_id") @db.Uuid
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  customer    Customer     @relation(fields: [customerId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])
  staff       User         @relation("ConsultationStaff", fields: [staffId], references: [id])

  @@index([customerId, consultedAt(sort: Desc)])
  @@map("consultations")
}

// -----------------------------------------------------------------------------
// 2. 계약 구분·계약 버전
// -----------------------------------------------------------------------------

model ContractType {
  id          String   @id @db.Uuid
  code        String   @unique @map("code") @db.VarChar(40)
  name        String   @map("name") @db.VarChar(100)
  description String?  @map("description")
  sortOrder   Int      @default(0) @map("sort_order")
  active      Boolean  @default(true) @map("active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  lines     ContractTypeLine[]
  contracts Contract[]

  @@map("contract_types")
}

model ContractTypeLine {
  id              String   @id @db.Uuid
  contractTypeId  String   @map("contract_type_id") @db.Uuid
  transactionType String   @map("transaction_type") @db.VarChar(20)
  productCategory String   @map("product_category") @db.VarChar(20)
  defaultQuantity Int      @default(1) @map("default_quantity")
  sortOrder       Int      @default(0) @map("sort_order")
  active          Boolean  @default(true) @map("active")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  contractType ContractType @relation(fields: [contractTypeId], references: [id])

  @@map("contract_type_lines")
}

model Contract {
  id               String    @id @db.Uuid
  contractNo       String    @unique @map("contract_no") @db.VarChar(40)
  customerId       String    @map("customer_id") @db.Uuid
  contractTypeId   String?   @map("contract_type_id") @db.Uuid
  status           String    @default("DRAFT") @map("status") @db.VarChar(20)
  currentVersionId String?   @map("current_version_id") @db.Uuid
  contractedAt     DateTime? @map("contracted_at") @db.Timestamptz(6)
  balanceDueDate   DateTime? @map("balance_due_date") @db.Date
  rowVersion       Int       @default(0) @map("row_version")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  customer       Customer          @relation(fields: [customerId], references: [id])
  contractType   ContractType?     @relation(fields: [contractTypeId], references: [id])
  currentVersion ContractVersion?  @relation("ContractCurrentVersion", fields: [currentVersionId], references: [id])
  versions       ContractVersion[] @relation("ContractVersions")
  orders         Order[]
  payments       Payment[]

  @@index([customerId, contractedAt(sort: Desc)])
  @@map("contracts")
}

model ContractVersion {
  id                String    @id @db.Uuid
  contractId        String    @map("contract_id") @db.Uuid
  versionNo         Int       @map("version_no")
  versionStatus     String    @default("DRAFT") @map("version_status") @db.VarChar(20)
  changeReason      String?   @map("change_reason")
  totalAmount       Decimal   @default(0) @map("total_amount") @db.Decimal(14, 2)
  depositAmount     Decimal   @default(0) @map("deposit_amount") @db.Decimal(14, 2)
  balanceAmount     Decimal   @default(0) @map("balance_amount") @db.Decimal(14, 2)
  completionDueDate DateTime? @map("completion_due_date") @db.Date
  photoDate         DateTime? @map("photo_date") @db.Date
  weddingDate       DateTime? @map("wedding_date") @db.Date
  confirmedBy       String?   @map("confirmed_by") @db.Uuid
  confirmedAt       DateTime? @map("confirmed_at") @db.Timestamptz(6)
  createdBy         String    @map("created_by") @db.Uuid
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  contract           Contract       @relation("ContractVersions", fields: [contractId], references: [id])
  confirmedByUser    User?          @relation("ContractVersionConfirmedBy", fields: [confirmedBy], references: [id])
  createdByUser      User           @relation("ContractVersionCreatedBy", fields: [createdBy], references: [id])
  currentOfContracts Contract[]     @relation("ContractCurrentVersion")
  lines              ContractLine[]

  @@unique([contractId, versionNo])
  @@map("contract_versions")
}

model ContractLine {
  id                String   @id @db.Uuid
  contractVersionId String   @map("contract_version_id") @db.Uuid
  transactionType   String   @map("transaction_type") @db.VarChar(20)
  productCategory   String   @map("product_category") @db.VarChar(20)
  itemDescription   String?  @map("item_description") @db.VarChar(150)
  quantity          Int      @map("quantity")
  unitPrice         Decimal? @map("unit_price") @db.Decimal(14, 2)
  lineAmount        Decimal  @default(0) @map("line_amount") @db.Decimal(14, 2)
  notes             String?  @map("notes")
  sortOrder         Int      @default(0) @map("sort_order")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  contractVersion ContractVersion @relation(fields: [contractVersionId], references: [id])
  orderItems      OrderItem[]

  @@index([contractVersionId, transactionType, productCategory])
  @@map("contract_lines")
}

// -----------------------------------------------------------------------------
// 2. 주문·품목·구성품
// -----------------------------------------------------------------------------

model Order {
  id                String    @id @db.Uuid
  orderNo           String    @unique @map("order_no") @db.VarChar(40)
  contractId        String    @map("contract_id") @db.Uuid
  transactionType   String    @map("transaction_type") @db.VarChar(20)
  status            String    @default("CREATED") @map("status") @db.VarChar(30)
  completionDueDate DateTime? @map("completion_due_date") @db.Date
  photoDate         DateTime? @map("photo_date") @db.Date
  weddingDate       DateTime? @map("wedding_date") @db.Date
  rowVersion        Int       @default(0) @map("row_version")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  contract              Contract              @relation(fields: [contractId], references: [id])
  items                 OrderItem[]
  measurementSessions   MeasurementSession[]
  repairRequests        RepairRequest[]
  notificationHistories NotificationHistory[]
  journeys              CustomerJourney[]

  @@unique([contractId, transactionType])
  @@map("orders")
}

model OrderItem {
  id                   String    @id @db.Uuid
  orderId              String    @map("order_id") @db.Uuid
  sourceContractLineId String    @map("source_contract_line_id") @db.Uuid
  productCategory      String    @map("product_category") @db.VarChar(20)
  sequenceNo           Int       @map("sequence_no")
  displayName          String    @map("display_name") @db.VarChar(100)
  status               String    @default("CREATED") @map("status") @db.VarChar(30)
  cancelledReason      String?   @map("cancelled_reason")
  cancelledAt          DateTime? @map("cancelled_at") @db.Timestamptz(6)
  rowVersion           Int       @default(0) @map("row_version")
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  order                   Order                    @relation(fields: [orderId], references: [id])
  sourceContractLine      ContractLine             @relation(fields: [sourceContractLineId], references: [id])
  components              OrderItemComponent[]
  optionSelectionSessions OptionSelectionSession[]
  measurementLinks        OrderItemMeasurement[]
  workOrder               WorkOrder?
  productionEvents        ProductionEvent[]
  fittingSessions         FittingSession[]
  repairRequests          RepairRequest[]

  @@unique([orderId, productCategory, sequenceNo])
  @@map("order_items")
}

model OrderItemComponent {
  id                  String    @id @db.Uuid
  orderItemId         String    @map("order_item_id") @db.Uuid
  componentType       String    @map("component_type") @db.VarChar(20)
  sequenceNo          Int       @default(1) @map("sequence_no")
  status              String    @default("CREATED") @map("status") @db.VarChar(30)
  expectedInboundDate DateTime? @map("expected_inbound_date") @db.Date
  actualInboundAt     DateTime? @map("actual_inbound_at") @db.Timestamptz(6)
  actualOutboundAt    DateTime? @map("actual_outbound_at") @db.Timestamptz(6)
  notes               String?   @map("notes")
  active              Boolean   @default(true) @map("active")
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  orderItem          OrderItem           @relation(fields: [orderItemId], references: [id])
  productionEvents   ProductionEvent[]
  fittingAdjustments FittingAdjustment[]
  rentalAllocations  RentalAllocation[]
  repairRequests     RepairRequest[]

  @@index([orderItemId, componentType])
  @@map("order_item_components")
}

// -----------------------------------------------------------------------------
// 3. 옵션 세트·임시저장·확정
// -----------------------------------------------------------------------------

model OptionSet {
  id              String   @id @db.Uuid
  productCategory String   @unique @map("product_category") @db.VarChar(20)
  name            String   @map("name") @db.VarChar(100)
  activeVersionId String?  @map("active_version_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  activeVersion OptionSetVersion?  @relation("OptionSetActiveVersion", fields: [activeVersionId], references: [id])
  versions      OptionSetVersion[] @relation("OptionSetVersions")

  @@map("option_sets")
}

model OptionSetVersion {
  id            String    @id @db.Uuid
  optionSetId   String    @map("option_set_id") @db.Uuid
  versionNo     Int       @map("version_no")
  status        String    @default("DRAFT") @map("status") @db.VarChar(20)
  effectiveFrom DateTime? @map("effective_from") @db.Date
  description   String?   @map("description")
  createdBy     String    @map("created_by") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  optionSet          OptionSet                @relation("OptionSetVersions", fields: [optionSetId], references: [id])
  createdByUser      User                     @relation("OptionSetVersionCreatedBy", fields: [createdBy], references: [id])
  activeOfOptionSets OptionSet[]              @relation("OptionSetActiveVersion")
  stages             OptionStage[]
  selectionSessions  OptionSelectionSession[]

  @@unique([optionSetId, versionNo])
  @@map("option_set_versions")
}

model OptionStage {
  id                 String   @id @db.Uuid
  optionSetVersionId String   @map("option_set_version_id") @db.Uuid
  stageCode          String   @map("stage_code") @db.VarChar(40)
  stageName          String   @map("stage_name") @db.VarChar(100)
  sequenceNo         Int      @map("sequence_no")
  required           Boolean  @default(true) @map("required")
  active             Boolean  @default(true) @map("active")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  optionSetVersion OptionSetVersion         @relation(fields: [optionSetVersionId], references: [id])
  choices          OptionChoice[]
  selectionValues  OptionSelectionValue[]
  currentSessions  OptionSelectionSession[] @relation("OptionSelectionSessionCurrentStage")

  @@unique([optionSetVersionId, stageCode])
  @@unique([optionSetVersionId, sequenceNo])
  @@map("option_stages")
}

model OptionChoice {
  id            String   @id @db.Uuid
  optionStageId String   @map("option_stage_id") @db.Uuid
  choiceCode    String   @map("choice_code") @db.Char(1)
  choiceName    String   @map("choice_name") @db.VarChar(100)
  factoryLabel  String?  @map("factory_label") @db.VarChar(100)
  imageFileId   String   @map("image_file_id") @db.Uuid
  /**
   * 이 선택지를 고를 때 계약금액에 더해지는 추가금액(원). 기본 선택지는 0.
   */
  extraPrice    Decimal  @default(0) @map("extra_price") @db.Decimal(12, 2)
  active        Boolean  @default(true) @map("active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  optionStage     OptionStage            @relation(fields: [optionStageId], references: [id])
  imageFile       File                   @relation(fields: [imageFileId], references: [id])
  selectionValues OptionSelectionValue[]

  @@unique([optionStageId, choiceCode])
  @@map("option_choices")
}

model OptionSelectionSession {
  id                 String    @id @db.Uuid
  orderItemId        String    @map("order_item_id") @db.Uuid
  optionSetVersionId String    @map("option_set_version_id") @db.Uuid
  selectionVersionNo Int       @map("selection_version_no")
  status             String    @default("NOT_STARTED") @map("status") @db.VarChar(20)
  currentStageId     String?   @map("current_stage_id") @db.Uuid
  fabricName         String?   @map("fabric_name") @db.VarChar(150)
  startedAt          DateTime? @map("started_at") @db.Timestamptz(6)
  lastSavedAt        DateTime? @map("last_saved_at") @db.Timestamptz(6)
  reviewedAt         DateTime? @map("reviewed_at") @db.Timestamptz(6)
  confirmedAt        DateTime? @map("confirmed_at") @db.Timestamptz(6)
  /**
   * 이 세션의 옵션 추가금액 중 계약금액에 이미 반영한 누계.
   * 재확정 시 (현재 합계 - 이 값)만 차액으로 더한다. 계약 버전은 올리지 않는다.
   */
  surchargeApplied   Decimal   @default(0) @map("surcharge_applied") @db.Decimal(12, 2)
  surchargeAppliedAt DateTime? @map("surcharge_applied_at") @db.Timestamptz(6)
  isCurrent          Boolean   @default(true) @map("is_current")
  rowVersion         Int       @default(0) @map("row_version")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  orderItem         OrderItem              @relation(fields: [orderItemId], references: [id])
  optionSetVersion  OptionSetVersion       @relation(fields: [optionSetVersionId], references: [id])
  currentStage      OptionStage?           @relation("OptionSelectionSessionCurrentStage", fields: [currentStageId], references: [id])
  values            OptionSelectionValue[]
  workOrderVersions WorkOrderVersion[]

  @@unique([orderItemId, selectionVersionNo])
  @@index([orderItemId, isCurrent, status])
  @@map("option_selection_sessions")
}

model OptionSelectionValue {
  id                 String   @id @db.Uuid
  selectionSessionId String   @map("selection_session_id") @db.Uuid
  optionStageId      String   @map("option_stage_id") @db.Uuid
  optionChoiceId     String   @map("option_choice_id") @db.Uuid
  /**
   * 선택 시점의 option_choices.extra_price 복사본.
   * 마스터 단가가 뒤에 바뀌어도 이미 선택된 건의 금액은 흔들리지 않는다.
   */
  extraPriceSnapshot Decimal  @default(0) @map("extra_price_snapshot") @db.Decimal(12, 2)
  selectedBy         String   @map("selected_by") @db.Uuid
  selectedAt         DateTime @default(now()) @map("selected_at") @db.Timestamptz(6)

  selectionSession OptionSelectionSession @relation(fields: [selectionSessionId], references: [id])
  optionStage      OptionStage            @relation(fields: [optionStageId], references: [id])
  optionChoice     OptionChoice           @relation(fields: [optionChoiceId], references: [id])
  selectedByUser   User                   @relation("OptionSelectionValueSelectedBy", fields: [selectedBy], references: [id])

  @@unique([selectionSessionId, optionStageId])
  @@map("option_selection_values")
}

