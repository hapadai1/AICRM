  newStatus      String    @map("new_status") @db.VarChar(30)
  expectedDate   DateTime? @map("expected_date") @db.Date
  eventDate      DateTime  @map("event_date") @db.Date
  notes          String?   @map("notes")
  actorId        String    @map("actor_id") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  orderItem OrderItem           @relation(fields: [orderItemId], references: [id])
  component OrderItemComponent? @relation(fields: [componentId], references: [id])
  actor     User                @relation("ProductionEventActor", fields: [actorId], references: [id])

  @@index([orderItemId, eventDate])
  @@index([eventType])
  @@index([expectedDate, newStatus])
  @@map("production_events")
}

model FittingSession {
  id                  String    @id @db.Uuid
  orderItemId         String    @map("order_item_id") @db.Uuid
