# PostgreSQL 접속 문자열
DATABASE_URL="postgresql://aicrm:aicrm@localhost:5432/aicrm_dev"

# JWT 서명 키 (운영 배포 시 반드시 교체)
JWT_SECRET="change-me-in-production"
JWT_ACCESS_EXPIRES="30m"
REFRESH_TOKEN_DAYS="14"

# 파일 저장 경로 (온프레미스 NAS 마운트 지점으로 교체 가능)
FILE_STORAGE_PATH="./storage"

PORT=3000

# 데모용: 알림톡 발송을 실패시켜 SMS 대체 발송을 시연할 번호(쉼표 구분). 비우면 항상 성공.
DEMO_ALIMTALK_FAIL_PHONES=""
